package pac1;
public interface Discountable {
	public double CalculateDiscount();

}

package pac1;
public class Product implements Discountable{
	private String name;
	private double price;
	private double discount;
	public Product(String name,double price,double discount)
	{
		this.name=name;
		this.price=price;
		this.discount=discount;
	}
	@Override
	public double CalculateDiscount() {
	return price-price*(discount/100);
	}
	public double getPrice()
	{
		return price;
	}
	public String getName()
	{
		return name;
	}
	public double getDiscount()
	{
		return discount;
	}
	public void final_price()
	{
		System.out.println("Final price with discount="+CalculateDiscount());
	}
	public void display()
	{
		System.out.println("Product Name:"+name+"\nPrice="+price+"\nFinal Price After Discount="+CalculateDiscount());
	}
}


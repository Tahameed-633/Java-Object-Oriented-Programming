package student_management_system;

public class Course {
    private String course_code;
    private String course_name;
    private double credit;
    private Department dept;
    
    public Course(String course_code, String course_name, double credit, Department dept)
    {
        this.course_code = course_code;
        this.course_name = course_name;
        this.credit = credit;
        this.dept = dept;
    }
    
    public void course_info()
    {
        System.out.println("Course Code: " + course_code);
        System.out.println("Course Title: " + course_name);
        System.out.println("Credit: " + credit);
    }
    
    public String get_course_code()
    {
        return course_code;
    }
}


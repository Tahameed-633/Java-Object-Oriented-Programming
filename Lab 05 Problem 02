package prob2;

public class PaySystem {
	protected double pay_rate;
	protected double hours;
	protected PaySystem(double pay_rate,double hours)
	{
		this.pay_rate=pay_rate;
		this.hours=hours;
	}
	protected double payment()
	{
		return (pay_rate)*hours;
	}
	protected void total_payment()
	{
		double a=payment();
		System.out.println("Total payment:"+a);
	}

}

package prob3;

public class SugerPurchase extends PurchaseSystem {
	protected double weight;
	protected SugerPurchase(int product_code, int unit_price, int quantity,double weight) {
		super(product_code, unit_price, quantity);
		this.weight=weight;
	}
	protected double total_payment()
	{
		total_price=unit_price*quantity*weight;
		return total_price;
	}
	protected void display()
	{
		System.out.println("Total Price="+total_payment());
	}


}

